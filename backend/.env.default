# ==== Backend Specific ENV
PORT=3000
HOST=0.0.0.0
JWT_ACCESS_KEY=my-secret-key
JWT_REFRESH_KEY=my-refresh-secret-key

# ===== Database Specific
 # Database password is used by docker compose file too. Please make sure to update it there as well if you change it here.
DATABASE_PASSWORD=password
DATABASE_USER=root
DATABASE_NAME=task_manager
DATABASE_PORT=3306
# Write Replica Host
DATABASE_HOST=0.0.0.0

# Read Replica Host
READ_DATABASE_HOST=

