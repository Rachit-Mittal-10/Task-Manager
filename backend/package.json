{
    "name": "backend",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "node --watch src/server.js",
        "debug": "node --watch --inspect src/server.js",
        "dev:ts": "tsx --watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "migrations": "node -r ts-node/register/transpile-only ../node_modules/.bin/knex",
        "migrate": "npm run migrations -- migrate:latest --knexfile src/knexfile.ts",
        "migrate:status": "npm run migrations -- migrate:status --knexfile src/knexfile.ts",
        "migrate:rollback": "npm run migrations -- migrate:rollback --knexfile src/knexfile.ts",
        "migrate:rollback-all": "npm run migrations -- migrate:rollback --all --knexfile src/knexfile.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.2",
        "knex": "^3.1.0",
        "mysql2": "^3.11.5",
        "ts-node": "^10.9.2",
        "util": "^0.12.5"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/dotenv": "^6.1.1",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/knex": "^0.15.2",
        "@types/node": "^22.19.13",
        "tsx": "^4.19.2",
        "typescript": "^5.6.3"
    },
    "imports": {
        "#/*": "./src/*",
        "#app/*": "./src/app/*",
        "#common/*": "./src/common/*",
        "#config/*": "./src/config/*",
        "#controllers/*": "./src/controllers/*",
        "#core/*": "./src/core/*",
        "#error/*": "./src/common/error/*",
        "#features/*": "./src/features/*",
        "#middleware/*": "./src/middleware/*",
        "#models/*": "./src/models/*",
        "#routes/*": "./src/routes/*",
        "#services/*": "./src/services/*",
        "#utils/*": "./src/common/utils/*"
    }
}
