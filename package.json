{
    "name": "task-manager",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "plop": "plop",
        "scaffold:backend": "plop backend-feature",
        "scaffold:frontend": "plop frontend-feature",
        "scaffold:component": "plop frontend-component",
        
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:backend": "eslint backend/",
        "lint:frontend": "eslint frontend/",
        "lint:fix:backend": "eslint backend/ --fix",
        "lint:fix:frontend": "eslint frontend/ --fix",
        "lint:file": "eslint",
        "lint:fix:file": "eslint --fix",
        
        "format": "prettier --write . --no-cache --ignore-path .prettierignore",
        "format:backend": "prettier --write backend/",
        "format:frontend": "prettier --write frontend/",
        "format:check": "prettier --check . --ignore-path .prettierignore",
        "format:check:backend": "prettier --check backend/",
        "format:check:frontend": "prettier --check frontend/",
        "format:file": "prettier --write",
        "lint:format": "eslint . --fix && prettier --write .",
        "lint:format:fix:backend": "eslint backend/ --fix && prettier --write backend/",
        "lint:format:fix:frontend": "eslint frontend/ --fix && prettier --write frontend/",
        
        "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
        "dev-ts": "concurrently \"npm --prefix backend run dev:ts\" \"npm --prefix frontend run dev\"",
        "dev:frontend": "npm --prefix frontend run dev",
        "dev:backend": "npm --prefix backend run dev",
        "dev-ts:backend": "npm --prefix backend run dev:ts",
        "build:frontend": "npm --prefix frontend run build",

        "migrate": "npm --prefix backend run migrate",
        "migrate:status": "npm --prefix backend run migrate:status",
        "migrate:rollback": "npm --prefix backend run migrate:rollback",
        "migrate:rollback-all": "npm --prefix backend run migrate:rollback-all",
        "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install",
        "install:runtime": "npm --prefix backend install --omit=dev && npm --prefix frontend install --omit=dev",
        "dependency:clear": "rm -rf node_modules package-lock.json frontend/node_modules frontend/package-lock.json backend/node_modules backend/package-lock.json"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "devDependencies": {
        "@babel/core": "^7.28.5",
        "@babel/eslint-parser": "^7.28.5",
        "@babel/preset-react": "^7.28.5",
        "concurrently": "^9.1.0",
        "eslint": "^9.17.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-react": "^7.37.3",
        "eslint-plugin-react-hooks": "^5.2.0",
        "plop": "^4.0.5",
        "prettier": "^3.4.2"
    }
}
